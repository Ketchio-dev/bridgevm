From: BridgeVM contributors
Subject: [PATCH] ArmVirt: process TPM2 physical-presence requests

ArmVirtQemu binds Tcg2PhysicalPresenceLibQemu when TPM2 is enabled, but its
lightweight platform boot manager never calls the request processor. Windows
can query PPI 1.3 through ACPI, yet every operation remains unsupported because
the firmware never initializes QEMU's shared PPI page.

Process requests at the end of PlatformBootManagerBeforeConsole, after
connecting the default consoles so user confirmation is possible, and crucially
before ConfigureTpmPlatformHierarchy () locks the platform hierarchy. The QEMU
PPI processor authorizes platform-hierarchy operations (for example Clear) with
an empty authorization; once ConfigureTpmPlatformHierarchy () randomizes and
discards platformAuth, that empty authorization is rejected with
TPM_RC_BAD_AUTH and the requested operation can never complete. This mirrors
OvmfPkg's full PlatformBootManagerLib, which processes the PPI request before
the hierarchy is locked.

The QEMU PPI parameter block is packed, so its 32-bit fields are intentionally
unaligned. Access them as volatile bytes: AArch64 Device memory faults on an
unaligned word access before the request can reach the virtual device.

diff --git a/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBm.c b/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBm.c
index 2c24c65..7698042 100644
--- a/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBm.c
+++ b/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBm.c
@@ -17,6 +17,7 @@
 #include <Library/PlatformBmPrintScLib.h>
 #include <Library/QemuBootOrderLib.h>
 #include <Library/QemuFwCfgSimpleParserLib.h>
+#include <Library/Tcg2PhysicalPresenceLib.h>
 #include <Library/TpmPlatformHierarchyLib.h>
 #include <Library/UefiBootManagerLib.h>
 #include <Protocol/DevicePath.h>
@@ -784,11 +785,6 @@ PlatformBootManagerBeforeConsole (
   //
   EfiEventGroupSignal (&gEfiEndOfDxeEventGroupGuid);

-  //
-  // Disable the TPM 2 platform hierarchy
-  //
-  ConfigureTpmPlatformHierarchy ();
-
   //
   // Dispatch deferred images after EndOfDxe event.
   //
@@ -916,6 +912,24 @@ PlatformBootManagerBeforeConsole (
   //
   FilterAndProcess (&gVirtioDeviceProtocolGuid, IsVirtioSerial, SetupVirtioSerial);
   FilterAndProcess (&gEfiPciIoProtocolGuid, IsVirtioPciSerial, SetupVirtioSerial);
+
+  //
+  // Connect the default consoles, then process any pending TPM2 physical-
+  // presence request while the platform hierarchy is still open. A requested
+  // operation (for example Clear) authorizes against the platform hierarchy
+  // with an empty authorization, which is only valid before
+  // ConfigureTpmPlatformHierarchy () randomizes and discards platformAuth.
+  // This mirrors OvmfPkg's full PlatformBootManagerLib, which processes the
+  // PPI request before locking the hierarchy; the console must be connected
+  // first so the user can confirm the operation.
+  //
+  EfiBootManagerConnectAllDefaultConsoles ();
+  Tcg2PhysicalPresenceLibProcessRequest (NULL);
+
+  //
+  // Disable the TPM 2 platform hierarchy now that PPI processing is complete.
+  //
+  ConfigureTpmPlatformHierarchy ();
 }

 /**
diff --git a/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBootManagerLib.inf b/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBootManagerLib.inf
index 9e89556..fac6a8d 100644
--- a/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBootManagerLib.inf
+++ b/OvmfPkg/Library/PlatformBootManagerLibLight/PlatformBootManagerLib.inf
@@ -49,6 +49,7 @@
   QemuLoadImageLib
   ReportStatusCodeLib
   TpmPlatformHierarchyLib
+  Tcg2PhysicalPresenceLib
   UefiBootManagerLib
   UefiBootServicesTableLib
   UefiLib
diff --git a/OvmfPkg/Library/Tcg2PhysicalPresenceLibQemu/DxeTcg2PhysicalPresenceLib.c b/OvmfPkg/Library/Tcg2PhysicalPresenceLibQemu/DxeTcg2PhysicalPresenceLib.c
index 4038020..de03060 100644
--- a/OvmfPkg/Library/Tcg2PhysicalPresenceLibQemu/DxeTcg2PhysicalPresenceLib.c
+++ b/OvmfPkg/Library/Tcg2PhysicalPresenceLibQemu/DxeTcg2PhysicalPresenceLib.c
@@ -43,7 +43,47 @@ EFI_HII_HANDLE  mTcg2PpStringPackHandle;
 #define TPM_PPI_FLAGS  (QEMU_TPM_PPI_FUNC_ALLOWED_USR_REQ)

 STATIC volatile QEMU_TPM_PPI  *mPpi;
-
+
+//
+// QEMU_TPM_PPI is packed and its UINT32 fields start at intentionally
+// unaligned offsets (0x101, 0x105, ...). AArch64 Device memory rejects an
+// unaligned word access before it can reach the device, so access those fields
+// as volatile bytes. This also preserves the little-endian PPI wire format.
+//
+STATIC
+UINT32
+QemuTpmPpiRead32 (
+  IN UINTN  Offset
+  )
+{
+  volatile UINT8  *Field;
+
+  Field = (volatile UINT8 *)mPpi + Offset;
+  return (UINT32)Field[0] |
+         ((UINT32)Field[1] << 8) |
+         ((UINT32)Field[2] << 16) |
+         ((UINT32)Field[3] << 24);
+}
+
+STATIC
+VOID
+QemuTpmPpiWrite32 (
+  IN UINTN   Offset,
+  IN UINT32  Value
+  )
+{
+  volatile UINT8  *Field;
+
+  Field    = (volatile UINT8 *)mPpi + Offset;
+  Field[0] = (UINT8)Value;
+  Field[1] = (UINT8)(Value >> 8);
+  Field[2] = (UINT8)(Value >> 16);
+  Field[3] = (UINT8)(Value >> 24);
+}
+
+#define PPI_READ32(Field)         QemuTpmPpiRead32 (OFFSET_OF (QEMU_TPM_PPI, Field))
+#define PPI_WRITE32(Field, Value) QemuTpmPpiWrite32 (OFFSET_OF (QEMU_TPM_PPI, Field), (Value))
+
 /**
   Reads QEMU PPI config from fw_cfg.

@@ -151,8 +191,8 @@ QemuTpmInitPPI (

   if (mPpi->In == 0) {
     mPpi->In          = 1;
-    mPpi->Request     = TCG2_PHYSICAL_PRESENCE_NO_ACTION;
-    mPpi->LastRequest = TCG2_PHYSICAL_PRESENCE_NO_ACTION;
+    PPI_WRITE32 (Request, TCG2_PHYSICAL_PRESENCE_NO_ACTION);
+    PPI_WRITE32 (LastRequest, TCG2_PHYSICAL_PRESENCE_NO_ACTION);
     mPpi->NextStep    = TCG2_PHYSICAL_PRESENCE_NO_ACTION;
   }

@@ -683,7 +723,7 @@ Tcg2HaveValidTpmRequest  (

   *RequestConfirmed = FALSE;

-  if (mPpi->Request <= TCG2_PHYSICAL_PRESENCE_NO_ACTION_MAX) {
+  if (PPI_READ32 (Request) <= TCG2_PHYSICAL_PRESENCE_NO_ACTION_MAX) {
     //
     // Need TCG2 protocol.
     //
@@ -693,7 +733,7 @@ Tcg2HaveValidTpmRequest  (
     }
   }

-  switch (mPpi->Request) {
+  switch (PPI_READ32 (Request)) {
     case TCG2_PHYSICAL_PRESENCE_NO_ACTION:
     case TCG2_PHYSICAL_PRESENCE_LOG_ALL_DIGESTS:
       *RequestConfirmed = TRUE;
@@ -735,7 +775,7 @@ Tcg2ExecutePendingTpmRequest (
 {
   BOOLEAN  RequestConfirmed;

-  if (mPpi->Request == TCG2_PHYSICAL_PRESENCE_NO_ACTION) {
+  if (PPI_READ32 (Request) == TCG2_PHYSICAL_PRESENCE_NO_ACTION) {
     //
     // No operation request
     //
@@ -746,15 +786,15 @@ Tcg2ExecutePendingTpmRequest (
     //
     // Invalid operation request.
     //
-    if (mPpi->Request <= TCG2_PHYSICAL_PRESENCE_NO_ACTION_MAX) {
-      mPpi->Response = TCG_PP_OPERATION_RESPONSE_SUCCESS;
+    if (PPI_READ32 (Request) <= TCG2_PHYSICAL_PRESENCE_NO_ACTION_MAX) {
+      PPI_WRITE32 (Response, TCG_PP_OPERATION_RESPONSE_SUCCESS);
     } else {
-      mPpi->Response = TCG_PP_OPERATION_RESPONSE_BIOS_FAILURE;
+      PPI_WRITE32 (Response, TCG_PP_OPERATION_RESPONSE_BIOS_FAILURE);
     }

-    mPpi->LastRequest      = mPpi->Request;
-    mPpi->Request          = TCG2_PHYSICAL_PRESENCE_NO_ACTION;
-    mPpi->RequestParameter = 0;
+    PPI_WRITE32 (LastRequest, PPI_READ32 (Request));
+    PPI_WRITE32 (Request, TCG2_PHYSICAL_PRESENCE_NO_ACTION);
+    PPI_WRITE32 (RequestParameter, 0);
     return;
   }

@@ -762,36 +802,39 @@ Tcg2ExecutePendingTpmRequest (
     //
     // Print confirm text and wait for approval.
     //
-    RequestConfirmed = Tcg2UserConfirm (mPpi->Request, mPpi->RequestParameter);
+    RequestConfirmed = Tcg2UserConfirm (PPI_READ32 (Request), PPI_READ32 (RequestParameter));
   }

   //
   // Execute requested physical presence command
   //
-  mPpi->Response = TCG_PP_OPERATION_RESPONSE_USER_ABORT;
+  PPI_WRITE32 (Response, TCG_PP_OPERATION_RESPONSE_USER_ABORT);
   if (RequestConfirmed) {
-    mPpi->Response = Tcg2ExecutePhysicalPresence (
-                       PlatformAuth,
-                       mPpi->Request,
-                       mPpi->RequestParameter
-                       );
+    PPI_WRITE32 (
+      Response,
+      Tcg2ExecutePhysicalPresence (
+        PlatformAuth,
+        PPI_READ32 (Request),
+        PPI_READ32 (RequestParameter)
+        )
+      );
   }

   //
   // Clear request
   //
-  mPpi->LastRequest      = mPpi->Request;
-  mPpi->Request          = TCG2_PHYSICAL_PRESENCE_NO_ACTION;
-  mPpi->RequestParameter = 0;
+  PPI_WRITE32 (LastRequest, PPI_READ32 (Request));
+  PPI_WRITE32 (Request, TCG2_PHYSICAL_PRESENCE_NO_ACTION);
+  PPI_WRITE32 (RequestParameter, 0);

-  if (mPpi->Response == TCG_PP_OPERATION_RESPONSE_USER_ABORT) {
+  if (PPI_READ32 (Response) == TCG_PP_OPERATION_RESPONSE_USER_ABORT) {
     return;
   }

   //
   // Reset system to make new TPM settings in effect
   //
-  switch (mPpi->LastRequest) {
+  switch (PPI_READ32 (LastRequest)) {
     case TCG2_PHYSICAL_PRESENCE_CLEAR:
     case TCG2_PHYSICAL_PRESENCE_ENABLE_CLEAR:
     case TCG2_PHYSICAL_PRESENCE_ENABLE_CLEAR_2:
@@ -806,7 +849,7 @@ Tcg2ExecutePendingTpmRequest (
       break;

     default:
-      if (mPpi->Request != TCG2_PHYSICAL_PRESENCE_NO_ACTION) {
+      if (PPI_READ32 (Request) != TCG2_PHYSICAL_PRESENCE_NO_ACTION) {
         break;
       }

@@ -853,7 +896,7 @@ Tcg2PhysicalPresenceLibProcessRequest (
     return;
   }

-  DEBUG ((DEBUG_INFO, "[TPM2PP] PPRequest=%x (PPRequestParameter=%x)\n", mPpi->Request, mPpi->RequestParameter));
+  DEBUG ((DEBUG_INFO, "[TPM2PP] PPRequest=%x (PPRequestParameter=%x)\n", PPI_READ32 (Request), PPI_READ32 (RequestParameter)));
   Tcg2ExecutePendingTpmRequest (PlatformAuth);
 }

@@ -885,8 +928,8 @@ Tcg2PhysicalPresenceLibReturnOperationResponseToOsFunction (
     return TCG_PP_RETURN_TPM_OPERATION_RESPONSE_FAILURE;
   }

-  *MostRecentRequest = mPpi->LastRequest;
-  *Response          = mPpi->Response;
+  *MostRecentRequest = PPI_READ32 (LastRequest);
+  *Response          = PPI_READ32 (Response);

   return TCG_PP_RETURN_TPM_OPERATION_RESPONSE_SUCCESS;
 }
@@ -921,8 +964,8 @@ Tcg2PhysicalPresenceLibSubmitRequestToPreOSFunction (
     return TCG_PP_SUBMIT_REQUEST_TO_PREOS_GENERAL_FAILURE;
   }

-  mPpi->Request          = OperationRequest;
-  mPpi->RequestParameter = RequestParameter;
+  PPI_WRITE32 (Request, OperationRequest);
+  PPI_WRITE32 (RequestParameter, RequestParameter);

   return TCG_PP_SUBMIT_REQUEST_TO_PREOS_SUCCESS;
 }
