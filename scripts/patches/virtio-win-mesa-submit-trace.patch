+/*
+ * Keep this diagnostic visible in release UMD builds.  The Windows smoke
+ * runner captures OutputDebugStringA, allowing us to distinguish an empty
+ * VirGL command buffer from a rejected D3D runtime render callback.
+ */
+static void
+bridgevm_trace_submit(const char *stage, struct virgl_gdi_cmd_buf *cbuf,
+                      unsigned command_length, long status)
+{
+   char message[256];
+   snprintf(message, sizeof(message),
+            "BV-VIRGL-SUBMIT stage=%s cdw=%u driver_length=%u command_length=%u allocations=%u status=0x%08lx cmd_buffer=%u alloc_list=%u patch_list=%u\n",
+            stage, cbuf->base.cdw, cbuf->driver_length, command_length,
+            cbuf->alloc_count, status, cbuf->ctx->CommandBufferSize,
+            cbuf->ctx->AllocationListSize, cbuf->ctx->PatchLocationListSize);
+   OutputDebugStringA(message);
+}
