@@ -416,6 +416,68 @@ struct sysval_uniform_block {
 
 static struct global_renderer_state vrend_state;
 
+#ifdef __APPLE__
+/* Apple's OpenGL driver can fault when glBufferData creates a fresh sysval UBO
+ * after a program has been linked.  Allocate one share-group buffer while ctx0
+ * is pristine, then refresh it before every serialized draw. */
+static GLuint vrend_apple_sysval_buffer_id;
+
+struct vrend_apple_buffer_texture_bindings {
+   GLint active_texture;
+   GLuint *textures;
+};
+
+/* Apple's legacy GL driver dereferences a null buffer-texture bind-point while
+ * updating a buffer object's shared-context stamp.  The fault is triggered by
+ * modifying (and, in practice, sometimes merely rebinding) any buffer while a
+ * GL_TEXTURE_BUFFER is bound on any texture unit.  Temporarily unbind every
+ * buffer texture around such operations, then restore the exact GL state so
+ * vrend's sampler binding cache remains truthful for the current draw. */
+static bool
+vrend_apple_buffer_modify_begin(struct vrend_apple_buffer_texture_bindings *saved)
+{
+   const GLuint count = vrend_state.max_texture_units;
+
+   memset(saved, 0, sizeof(*saved));
+   glGetIntegerv(GL_ACTIVE_TEXTURE, &saved->active_texture);
+   if (!count)
+      return true;
+
+   saved->textures = calloc(count, sizeof(*saved->textures));
+   if (!saved->textures) {
+      virgl_error("Unable to save Apple buffer-texture bindings\n");
+      return false;
+   }
+
+   for (GLuint unit = 0; unit < count; unit++) {
+      glActiveTexture(GL_TEXTURE0 + unit);
+      glGetIntegerv(GL_TEXTURE_BINDING_BUFFER,
+                    (GLint *)&saved->textures[unit]);
+      if (saved->textures[unit])
+         glBindTexture(GL_TEXTURE_BUFFER, 0);
+   }
+   glActiveTexture(saved->active_texture);
+   return true;
+}
+
+static void
+vrend_apple_buffer_modify_end(struct vrend_apple_buffer_texture_bindings *saved)
+{
+   if (!saved->textures)
+      return;
+
+   for (GLuint unit = 0; unit < vrend_state.max_texture_units; unit++) {
+      if (!saved->textures[unit])
+         continue;
+      glActiveTexture(GL_TEXTURE0 + unit);
+      glBindTexture(GL_TEXTURE_BUFFER, saved->textures[unit]);
+   }
+   glActiveTexture(saved->active_texture);
+   free(saved->textures);
+   saved->textures = NULL;
+}
