+/* Apple's legacy GL driver dereferences a null buffer-texture bind-point while
+ * updating a buffer object's shared-context stamp.  The fault is triggered by
+ * modifying (and, in practice, sometimes merely rebinding) any buffer while a
+ * GL_TEXTURE_BUFFER is bound on any texture unit.  Temporarily unbind every
+ * buffer texture around such operations, then restore the exact GL state so
+ * vrend's sampler binding cache remains truthful for the current draw. */
+static bool
+vrend_apple_buffer_modify_begin(struct vrend_apple_buffer_texture_bindings *saved)
+{
