+      glGetIntegerv(GL_TEXTURE_BINDING_BUFFER,
+                    (GLint *)&saved->textures[unit]);
+      if (saved->textures[unit])
+         glBindTexture(GL_TEXTURE_BUFFER, 0);
+   }
+   glActiveTexture(saved->active_texture);
+   return true;
